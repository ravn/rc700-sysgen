HARDDISK EQU	1
REL22PLUS EQU	1
	ENDIF
	IFDEF	REL30
HARDDISK EQU	1
REL22PLUS EQU	1
	ENDIF

	IFDEF	HARDDISK
CTC2C0	EQU	44H	; CTC 2 CHANNEL 0
CTC2C1	EQU	45H	; CTC 2 CHANNEL 1
CTC2C2	EQU	46H	; CTC 2 CHANNEL 2
CTC2C3	EQU	47H	; CTC 2 CHANNEL 3

HDDARG 	EQU	60H	; WD1000 DATA REGISTER
HDERRG	EQU	61H	; WD1000 ERROR REGISTER (READ ONLY)
HWPCMP	EQU	HDERRG	; WD1000 WRITE PRECOMP. REGISTER (WRITE ONLY)
HSECCT	EQU	62H	; WD1000 SECTOR COUNT
HSECNO	EQU	63H	; WD1000 SECTOR NUMBER
HCYLLO	EQU	64H	; WD1000 CYLINDER NO. LOW
HCYLHI	EQU	65H	; WD1000 CYLINDER NO. HIGH
HSZDHD	EQU	66H	; WD1000 SIZE/DRIVE/HEAD REGISTER
HDSTRG	EQU	67H	; WD1000 STATUS REGISTER (READ ONLY)
HCMDRG	EQU	HDSTRG	; WD1000 COMMAND REGISTER (WRITE ONLY)
	ENDIF

	PAGE

DMAC	EQU	0F8H	; DMA CONTROL
DMAMOD	EQU	0FBH	; DMA MODE REGISTER
DMAMAS	EQU	0FAH	; DMA MASK REGISTER
DMAAD0	EQU	0F0H	; ADDRESS REGISTERS
DMAAD1	EQU	0F2H	;
DMAAD2	EQU	0F4H	;
DMAAD3	EQU	0F6H	;
DMACN0	EQU	0F1H	; WORD COUNT REGISTERS
DMACN1	EQU	0F3H	;
DMACN2	EQU	0F5H	;
DMACN3	EQU	0F7H	;
DMACBC	EQU	0FCH	; CLEAR BYTE COUNTER
DMAREQ	EQU	0F9H	;
DMAMSK	EQU	0FFH	;
DMATMP	EQU	0FDH	;

DSPLC	EQU	001H	; DISPLAY CONTROL
DSPLD	EQU	000H	; DISPLAY DATA

FDC	EQU	004H	; FLOPPY CONTROL
FDD	EQU	005H	; FLOPPY DATA

BELL	EQU	01CH	;
SW1	EQU	014H	;

	PAGE

;========================================================
;= RAM LAYOUT DEFINITION                                =
;========================================================
	IFDEF	REL14
MSIZE	EQU	58		; AVAILABLE MEMORY EXCL. BIOS (58K)
	ENDIF
	IFDEF	REL20
MSIZE	EQU	56		; AVAILABLE MEMORY EXCL. BIOS (56K)
	ENDIF
	IFDEF	REL21
MSIZE	EQU	56		; AVAILABLE MEMORY EXCL. BIOS (56K)
	ENDIF
	IFDEF	REL22PLUS
MSIZE	EQU	56		; AVAILABLE MEMORY EXCL. BIOS (56K)
	ENDIF
BIAS	EQU	(MSIZE-20)*1024 ;
CPMB	EQU	3400H+BIAS	; CCP BASE
CCPCLR	EQU	CPMB+03H	; CCP-START ADDRESS +3
CPML	EQU	1600H		; LENGTH OF CCP AND BDOS
BDOS	EQU	CPMB+806H	; BDOS BASE
BIOS	EQU	CPMB+CPML	; BIOS BASE
BUFF	EQU	80H		; DMA BUFFER
IOBYTE	EQU	3		;
CDISK	EQU	4		; CURRENT LOGGED IN DISK
NSECTS	EQU	CPML/128	; LENGTH OF CCP AND BDOS IN 128 BYTES SECTORS
	IFDEF	REL14
CBOOT	EQU	380H		; ROM BOOTSTRAP LOADER ENTRY POINT (MAXI)
	ENDIF
	IFDEF	REL20
CBOOT	EQU	280H		; ROM BOOTSTRAP LOADER ENTRY POINT (MINI)
	ENDIF
	IFDEF	REL21
CBOOT	EQU	280H		; ROM BOOTSTRAP LOADER ENTRY POINT (MINI)
	ENDIF
	IFDEF	REL22PLUS
CBOOT	EQU	280H		; ROM BOOTSTRAP LOADER ENTRY POINT (MINI)
	ENDIF
	IFDEF	HARDDISK
PATCH1	EQU	CPMB+144CH	; FIRST PATCH ADDRESS TO WBOOT FROM HD
PATCH2	EQU	CPMB+149AH	; SECOND DO.
	ENDIF
	IFDEF	REL14
START	EQU	0DD00H		; START OF CODE (INIT + BIOS) (58K)
	ENDIF
	IFDEF	REL20
START	EQU	0D480H		; START OF CODE (INIT + BIOS) (56K)
	ENDIF
	IFDEF	REL21
START	EQU	0D480H		; START OF CODE (INIT + BIOS) (56K)
	ENDIF
	IFDEF	REL22PLUS
START	EQU	0D480H		; START OF CODE (INIT + BIOS) (56K)
	ENDIF
; BGSTAR, ISTACK, STACK defined in upper memory DS block
	IFDEF	REL14
ENDPRG	EQU	0F168H		; RESERVED AREA FOR BIOS VARIABLES (58K)
	ENDIF
	IFDEF	REL20
ENDPRG	EQU	0EE7FH		; RESERVED AREA FOR BIOS VARIABLES (56K)
	ENDIF
	IFDEF	REL21
ENDPRG	EQU	0EE80H		; RESERVED AREA FOR BIOS VARIABLES (56K)
	ENDIF
	IFDEF	REL22PLUS
ENDPRG	EQU	0EE80H		; RESERVED AREA FOR BIOS VARIABLES (56K)
	ENDIF
; OUTCON, INCONV, DSPSTR defined in upper memory DS block

; Floppy driver variables, disk parameters, and REL30 ring buffers
; defined in floppy variables DS block (after .DEPHASE)

	IFDEF	REL30
RXBUFSZ	EQU	256			; SIO RING BUFFER SIZE (POWER OF 2, MAX 256)
RXMASK	EQU	RXBUFSZ-1		; WRAPPING MASK (0FFH FOR 256)
RXTHHI	EQU	RXBUFSZ-8		; RCA: DE-ASSERT RTS WHEN USED >= THIS
RXTHLO	EQU	RXBUFSZ-16		; READER: RE-ASSERT RTS WHEN USED < THIS
	ENDIF

	IFDEF	HARDDISK
;==============================================================================
;=	WD1000 MACRO COMMAND DEFINITIONS                                      =
;==============================================================================

RSTCMD	EQU	10H 		; RESTOTE COMMAND
RDCMD	EQU	28H 		; READ SECTOR WITH DMA COMMAND
WRTCMD	EQU	30H 		; WRITE SECTOR COMMAND
FMTCMD	EQU	50H 		; FORMAT TRACK COMMAND
SEEKCM	EQU	70H 		; SEEK COMMAND
	ENDIF

	PAGE

	INCLUDE		BIOSTYPE.MAC
